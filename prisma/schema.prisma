generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum TermName {
  FIRST
  SECOND
  THIRD
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                Role?
  status              Status   @default(PENDING)
  studentId           String?  @unique
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Teacher-owned academic structure
  academicYears AcademicYear[]

  // Student relations
  enrollments   Enrollment[]
  grades        Grade[]
  gradeHistoryChanges GradeHistory[] @relation("ChangedBy")

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model AcademicYear {
  id        String   @id @default(cuid())
  label     String   // e.g. "2025-2026"
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())
  archived  Boolean  @default(false)

  terms Term[]

  @@unique([teacherId, label])
  @@map("academic_years")
}

model Term {
  id             String       @id @default(cuid())
  name           TermName
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  createdAt      DateTime     @default(now())

  classes Class[]

  @@unique([academicYearId, name])
  @@map("terms")
}

model Class {
  id        String   @id @default(cuid())
  name      String   // e.g. "Grade 11 - STEM A"
  termId    String
  term      Term     @relation(fields: [termId], references: [id])
  createdAt DateTime @default(now())
  archived  Boolean  @default(false)

  subjects Subject[]

  @@map("classes")
}

model Subject {
  id        String   @id @default(cuid())
  name      String   // e.g. "General Mathematics"
  code      String
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  createdAt DateTime @default(now())
  archived  Boolean  @default(false)

  enrollments Enrollment[]
  grades      Grade[]

  @@unique([classId, code])
  @@map("subjects")
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  subjectId  String
  student    User     @relation(fields: [studentId], references: [id])
  subject    Subject  @relation(fields: [subjectId], references: [id])
  enrolledAt DateTime @default(now())

  @@unique([studentId, subjectId])
  @@map("enrollments")
}

model Grade {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  value     Float
  student   User     @relation(fields: [studentId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  history GradeHistory[]

  @@unique([studentId, subjectId])
  @@map("grades")
}

model GradeHistory {
  id          String   @id @default(cuid())
  gradeId     String
  oldValue    Float?
  newValue    Float
  grade       Grade    @relation(fields: [gradeId], references: [id])
  changedById String
  changedBy   User     @relation("ChangedBy", fields: [changedById], references: [id])
  changedAt   DateTime @default(now())

  @@map("grade_history")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}